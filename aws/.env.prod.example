# JiApp PRODUCTION runtime secrets — copy to aws/.env.prod (gitignored) and fill in.
#   cp aws/.env.prod.example aws/.env.prod
# release.sh uploads this file to S3 (s3://jiapp-deploy-config-<acct>/ec2/.env),
# which EC2 downloads to /opt/jiapp/.env and sources for docker-compose.
# NEVER commit aws/.env.prod or hand-edit .env directly on the EC2 instance.

# Required: JWT signing key (>= 32 chars). Generate: openssl rand -base64 32
JWT_KEY=

# Required: YouTube Data API key for the YtDownloader service
YOUTUBE_API_KEY=

# Required: PFX certificate password for Gateway HTTPS (server.pfx)
CERT_PASSWORD=

# Required for the DeepSeek YouTube assistant (chat). Without it the assistant returns 503.
DEEPSEEK_API_KEY=

# Optional: override the DeepSeek model (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Optional: YouTube cookies in Netscape format to bypass datacenter-IP bot checks.
# To set up:
# 1. Export cookies from a logged-in browser (Netscape format) into
#    backend/certs/prod/youtube/youtube-cookies.txt (this dir is gitignored).
# 2. Set this to the in-container path: /app/cookies/youtube-cookies.txt
# When unset or empty, downloads run without cookies (current behavior).
# YOUTUBE_COOKIES_FILE=/app/cookies/youtube-cookies.txt

# Optional: residential proxy URL for yt-dlp to bypass YouTube's datacenter-IP bot block.
# Format: http://user:pass@host:port  (or socks5://...). Only yt-dlp uses it.
# YOUTUBE_PROXY=

# Username whose account is auto-promoted to the Admin role on startup IF the
# Admin role has zero members (self-heals admin lockouts after migrations).
# Must equal an existing account's login UserName. Leave empty to disable.
BOOTSTRAP_ADMIN_USERNAME=
