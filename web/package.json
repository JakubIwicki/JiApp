{
  "name": "jakubiwicki-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check:no-placeholder": "grep -rq REPLACE_ME dist && { echo 'ERROR: REPLACE_ME placeholder present in build output — set the real S3 URL in src/config.ts before deploying'; exit 1; } || echo 'OK: no REPLACE_ME in dist'"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
