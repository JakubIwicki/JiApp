# JiApp Mobile — environment configuration template.
# Copy this file to .env and customize:
#   cp .env.example .env
#
# The build-apk.sh --prod / --dev flag selects which environment to bake.
# If neither flag is given and stdin is a TTY, you will be prompted.
#
# Build commands:
#   ./build-apk.sh --prod                     # PROD (AWS) debug APK
#   ./build-apk.sh --dev --release            # DEV (LAN) release APK
#   ./build-apk.sh --prod --release --install # PROD release + install

# ── PRODUCTION (AWS) — used by --prod builds ─────────────────────────────
# The backend API gateway on the AWS Elastic IP.
JIAPP_API_URL=https://<your-elastic-ip>:6700/api/v1

# Wake Lambda URL — API Gateway endpoint that starts the EC2 instance.
JIAPP_WAKE_API_URL=https://abc123.execute-api.eu-central-1.amazonaws.com

# Production Elastic IP — injected into Android network security config for HTTPS trust.
JIAPP_PROD_IP=<your-production-elastic-ip>

# ── DEV (LAN) — used by --dev builds ─────────────────────────────────────
# Your dev machine LAN IP (required for physical Android devices).
# Emulator users: set this to https://10.0.2.2:6700/api/v1
JIAPP_DEV_API_URL=https://<your-dev-ip>:6700/api/v1
