# JiApp Mobile — local development overrides
# Copy this file to .env and customize:
#   cp .env.example .env

# Your dev machine LAN IP (required for physical Android devices)
# Emulator users can leave this unset (defaults to 10.0.2.2).
JIAPP_API_URL=https://<your-dev-ip>:6700/api/v1

# Wake API URL — Lambda via API Gateway that starts the EC2 instance.
# Required for production builds. Leave as example for development.
JIAPP_WAKE_API_URL=https://abc123.execute-api.eu-central-1.amazonaws.com

# Production Elastic IP — injected into Android network security config for HTTPS trust.
# Required for production builds. Leave as example for development.
JIAPP_PROD_IP=<your-production-elastic-ip>
