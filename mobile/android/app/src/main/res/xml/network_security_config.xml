<!--
  Dev cert trust for emulator (10.0.2.2).
  For physical device development, build-apk.sh injects your LAN IP
  from mobile/.env into the domain list below.
-->
<network-security-config>
    <base-config>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- DEVICE_IP_BEGIN -->
        <!-- DEVICE_IP_END -->
        <trust-anchors>
            <certificates src="@raw/jiapp_dev_ca" />
        </trust-anchors>
    </domain-config>
</network-security-config>
