<!--
  Dev cert trust for emulator (10.0.2.2) and physical devices (LAN IP).
  Sync with mobile/.env JIAPP_API_URL when IP changes.
-->
<network-security-config>
    <base-config>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.100.105</domain>
        <trust-anchors>
            <certificates src="@raw/jiapp_dev_ca" />
        </trust-anchors>
    </domain-config>
</network-security-config>
