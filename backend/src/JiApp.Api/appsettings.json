{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5001"
      }
    }
  },
  "App": {
    "BaseDirectory": "${BaseDirectory}"
  },
  "ConnectionStrings": {
    "JiDb": "Data Source=${BaseDirectory}JiApp.db"
  },
  "Youtube": {
    "api-key": "${YOUTUBE_API_KEY}",
    "yt-dlp": "yt-dlp",
    "ffmpeg": "ffmpeg"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "JiApp",
    "Audience": "http://localhost:5001",
    "ExpireMinutes": 30
  }
}
