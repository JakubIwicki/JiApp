{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5001"
      }
    }
  },
  "App": {
    "BaseDirectory": "${BaseDirectory}"
  },
  "ConnectionStrings": {
    "JiDb": "Data Source=${BaseDirectory}JiApp.db"
  },
  "Youtube": {
    "api-key": "${YOUTUBE_API_KEY}",
    "yt-dlp": "yt-dlp",
    "ffmpeg": "ffmpeg"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "JiApp",
    "Audience": "http://localhost:5001",
    "ExpireMinutes": 30
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowInSeconds": 60,
      "QueueLimit": 0
    },
    "Register": {
      "PermitLimit": 3,
      "WindowInSeconds": 60,
      "QueueLimit": 0
    },
    "Health": {
      "PermitLimit": 30,
      "WindowInSeconds": 60,
      "QueueLimit": 0
    },
    "DownloadFile": {
      "PermitLimit": 10,
      "WindowInSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4
    }
  }
}
