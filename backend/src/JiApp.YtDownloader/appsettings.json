{
  "Serilog": {
    "Using": ["Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ytdownloader-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://*:6702"
      }
    }
  },
  "App": {
    "BaseDirectory": "/tmp",
    "PreviewDurationSeconds": 10
  },
  "ConnectionString": "Data Source=../../.data/ytdownloader_dev.db;Foreign Keys=True",
  "Youtube": {
    "ApiKey": "",
    "YtDlpPath": "yt-dlp",
    "FfmpegPath": "ffmpeg",
    "CookiesFile": "",
    "CookiesFromBrowser": "",
    "Proxy": "",
    "MaxResults": 30,
    "PageSize": 10
  },
  "Jwt": {
    "Key": "",
    "Issuer": "JiApp-Identity",
    "Audience": "jiapp-gateway"
  },
  "DeepSeek": {
    "ApiKey": "",
    "BaseUrl": "https://api.deepseek.com",
    "Model": "deepseek-chat",
    "MaxIterations": 5,
    "RequestTimeoutSeconds": 60
  },
  "Assistant": {
    "DailyMessageLimitPerUser": 30
  }
}
