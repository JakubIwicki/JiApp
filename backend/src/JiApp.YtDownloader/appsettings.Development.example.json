{
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://*:6702",
        "Certificate": {
          "Path": "../../certs/dev-cert.pfx",
          "Password": "${CERT_PASSWORD}"
        }
      }
    }
  },
  "ConnectionString": "Data Source=/path/to/dev.db",
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "JiApp-Identity",
    "Audience": "jiapp-gateway"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
