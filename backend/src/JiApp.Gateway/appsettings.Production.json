{
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://*:6700"
      }
    }
  },
  "RateLimiting": {
    "Scheduler": {
      "PermitLimit": 30,
      "WindowInSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4
    },
    "LovingBoards": {
      "PermitLimit": 30,
      "WindowInSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/gateway-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  }
}
