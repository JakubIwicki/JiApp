{
  // HTTPS is terminated upstream (load balancer / reverse proxy).
  // Kestrel HTTPS endpoint was intentionally removed — Docker runs HTTP
  // internally via ASPNETCORE_HTTP_PORTS. Do not add HTTPS here.
  "RateLimiting": {
    "Scheduler": {
      "PermitLimit": 30,
      "WindowInSeconds": 60,
      "QueueLimit": 0,
      "SegmentsPerWindow": 4
    }
  }
}
