# JiApp production secrets — copy to .env and fill in values
#   cp .env.example .env

# Required: PostgreSQL password for the 'jiapp' user
POSTGRES_PASSWORD=

# Required: JWT signing key (at least 32 characters, use a strong random string)
# Generate: openssl rand -base64 32
JWT_KEY=

# Required: YouTube Data API key for YtDownloader service
YOUTUBE_API_KEY=

# YouTube cookie authentication for yt-dlp (optional — avoids HTTP 429 rate limiting).
# For LOCAL development: set CookiesFromBrowser to a browser name (e.g. firefox, chrome)
# to extract cookies from your local browser's cookie store.
#   YOUTUBE_COOKIES_FROM_BROWSER=firefox
# For Docker/PRODUCTION deployments: set CookiesFile to a Netscape-format cookie file
# mounted into the container. CookiesFromBrowser does NOT work in Docker (no browser
# cookie store available inside the container).
#   YOUTUBE_COOKIES_FILE=/app/cookies.txt
# If neither is set, yt-dlp runs without authentication cookies (may get 429).

# ── Optional overrides (defaults shown) ─────────────────────────────────────
# JWT_ISSUER=JiApp-Identity
# JWT_AUDIENCE=jiapp-gateway
# JWT_ACCESS_EXPIRE=15
# JWT_REFRESH_EXPIRE=7
